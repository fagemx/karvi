{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "custom-ai-t8star-cn": {
      "name": "T8Star AI",
      "npm": "@ai-sdk/openai-compatible",
      "env": ["T8STAR_API_KEY"],
      "models": {
        "claude-sonnet-4": {
          "name": "Claude Sonnet 4",
          "tool_call": true,
          "limit": { "context": 200000, "output": 16384 }
        },
        "claude-opus-4": {
          "name": "Claude Opus 4",
          "tool_call": true,
          "limit": { "context": 200000, "output": 16384 }
        },
        "gpt-5.3-codex-high": {
          "name": "GPT 5.3 Codex High",
          "tool_call": true,
          "limit": { "context": 200000, "output": 16384 }
        }
      },
      "options": {
        "baseURL": "https://ai.t8star.cn/v1"
      }
    }
  }
}
